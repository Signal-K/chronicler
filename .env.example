# ─────────────────────────────────────────────────────────────────────────────
# Bee Garden – environment variable reference
# Copy this file to .env.local (or private/project-env/client.env) and fill in
# your real values. These files are git-ignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for auth, cloud save sync, and progress preservation.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── PostHog ───────────────────────────────────────────────────────────────────
# Required for in-app event capture and feedback surveys.
EXPO_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Used by scripts/posthog/create_surveys.sh to create/update survey definitions.
POSTHOG_PERSONAL_API_KEY=phx_your_personal_api_key
POSTHOG_PROJECT_ID=your_project_id
# Optional – override if you use EU PostHog:
# POSTHOG_HOST=https://eu.posthog.com

# ── Next.js / Web build ───────────────────────────────────────────────────────
# Required for the web export and PWA host.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── EAS / Build ───────────────────────────────────────────────────────────────
# Supabase secrets for EAS builds are set as EAS environment variables in the
# Expo dashboard (https://expo.dev) and are NOT stored here. The eas.json
# "environment": "production" build profile references those cloud values.
# Never add EAS_SECRET_* values to this file.
