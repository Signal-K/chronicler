{
  "cli": {
    "version": ">= 16.19.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "local": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "environment": "production"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "environment": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
